{
  "multipart": [
    {
      "apply": {
        "model": "pastel:block/jadeite_lotus_stem_bottom"
      },
      "when": {
        "part": "stem"
      }
    },
    {
      "apply": {
        "model": "pastel:block/jadeite_lotus_stem_top"
      },
      "when": {
        "part": "stemalt"
      }
    },
    {
      "apply": {
        "model": "pastel:block/jadeite_lotus_stem_bottom"
      },
      "when": {
        "part": "base"
      }
    },
    {
      "apply": {
        "model": "pastel:block/jadeite_lotus_stem_base"
      },
      "when": {
        "inverted": "false",
        "part": "base"
      }
    },
    {
      "apply": {
        "model": "pastel:block/jadeite_lotus_stem_base",
        "x": 180
      },
      "when": {
        "inverted": "true",
        "part": "base"
      }
    }
  ]
}